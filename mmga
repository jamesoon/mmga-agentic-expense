#!/usr/bin/env bash
# mmga — CLI for managing the MMGA Expense AI deployment
# Usage: ./mmga <command> [args]
#
# SSH mode (full ops — requires SSH key to EC2):
#   deploy, restart, cleanup, ssh, env, logs clear
#
# API mode (anyone with reviewer login):
#   status, logs, models, agent

set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────────────
APP_URL="https://mmga.mdaie-sutd.fit"
EC2_HOST="ec2-user@13.213.13.39"
EC2_PROJECT="/opt/mmga-expense"
LOCAL_ROOT="$(cd "$(dirname "$0")" && pwd)"
COOKIE_JAR="${HOME}/.mmga_session"
LOGS_DIR="${LOCAL_ROOT}/logs"

# ── Colors ──────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

# ── Helpers ─────────────────────────────────────────────────────────────────
info()  { echo -e "${CYAN}${BOLD}>>>${NC} $*"; }
ok()    { echo -e "${GREEN}${BOLD} ok${NC} $*"; }
warn()  { echo -e "${YELLOW}${BOLD} !!${NC} $*"; }
err()   { echo -e "${RED}${BOLD}ERR${NC} $*" >&2; }
dim()   { echo -e "${DIM}$*${NC}"; }
header(){ echo -e "\n${BOLD}── $* ──${NC}"; }

has_ssh() {
  ssh -o BatchMode=yes -o ConnectTimeout=3 "$EC2_HOST" "true" 2>/dev/null
}

require_ssh() {
  if ! has_ssh; then
    err "SSH access to EC2 required for this command."
    err "Run ${BOLD}mmga ssh${NC} to test connectivity."
    exit 1
  fi
}

ec2() {
  ssh "$EC2_HOST" "$@" 2>&1
}

# ── API Auth ────────────────────────────────────────────────────────────────
api_login() {
  if [ -f "$COOKIE_JAR" ]; then
    # Test if session is still valid
    local code
    code=$(curl -s -o /dev/null -w "%{http_code}" -b "$COOKIE_JAR" "${APP_URL}/health/json" 2>/dev/null || echo "000")
    if [ "$code" = "200" ]; then
      return 0
    fi
    rm -f "$COOKIE_JAR"
  fi

  echo -e "${CYAN}Login required.${NC} Enter your MMGA reviewer credentials."
  read -rp "Username: " username
  read -rsp "Password: " password
  echo

  # POST login form, capture cookie jar
  curl -s -o /dev/null \
    -c "$COOKIE_JAR" -L \
    --data-urlencode "username=${username}" \
    --data-urlencode "password=${password}" \
    --data-urlencode "remember_me=on" \
    "${APP_URL}/login" 2>/dev/null

  # Verify the session works by hitting a protected endpoint
  local verify
  verify=$(curl -s -o /dev/null -w "%{http_code}" -b "$COOKIE_JAR" "${APP_URL}/health/json" 2>/dev/null || echo "000")
  if [ "$verify" = "200" ]; then
    ok "Logged in as ${BOLD}${username}${NC}"
    return 0
  else
    rm -f "$COOKIE_JAR"
    err "Login failed. Check your credentials."
    return 1
  fi
}

api_get() {
  local endpoint="$1"
  api_login || return 1
  curl -s -b "$COOKIE_JAR" "${APP_URL}${endpoint}" 2>/dev/null
}

# ── Commands ────────────────────────────────────────────────────────────────

cmd_status() {
  header "System Health"
  local json
  json=$(api_get "/health/json")
  if [ -z "$json" ] || [ "$json" = "null" ]; then
    err "Could not fetch health data."
    return 1
  fi

  # Parse with python for portability (jq not always available)
  echo "$json" | python3 -c "
import sys, json
d = json.load(sys.stdin)
ts = d.get('timestamp', '?')
dur = d.get('durationMs', '?')
print(f'  Checked:  {ts}')
print(f'  Duration: {dur}ms')
print()

checks = d.get('checks', {})
for name, info in checks.items():
    status = info.get('status', '?')
    icon = '\033[0;32m OK\033[0m' if status == 'ok' else '\033[0;31mFAIL\033[0m'
    latency = info.get('latencyMs', '')
    lat_str = f' ({latency}ms)' if latency else ''
    print(f'  {icon}  {name}{lat_str}')

    # Show model info for OpenRouter
    if 'primaryLlm' in info:
        print(f'        LLM: {info[\"primaryLlm\"]}')
        print(f'        VLM: {info[\"primaryVlm\"]}')
        if info.get('fallbackLlm'):
            print(f'        Fallback: {info[\"fallbackLlm\"]}')
print()
"

  # If SSH available, also show disk and uptime
  if has_ssh; then
    dim "  (SSH connected — showing server info)"
    ec2 "echo -n '  Disk: '; df -h / | awk 'NR==2{print \$3\"/\"\$2\" used (\" \$5 \")\"}'; echo -n '  Uptime: '; uptime -p 2>/dev/null || uptime"
  fi
}

cmd_logs() {
  local subcmd="${1:-tail}"
  shift 2>/dev/null || true

  case "$subcmd" in
    tail|"")
      local lines="${1:-50}"
      header "App Logs (last ${lines} lines)"
      # Try API first
      local json
      json=$(api_get "/logs/json")
      if [ -n "$json" ] && [ "$json" != "null" ]; then
        echo "$json" | python3 -c "
import sys, json
data = json.load(sys.stdin)
services = data.get('services', {})
for svc, info in services.items():
    errors = info.get('errors', [])
    warnings = info.get('warnings', [])
    label = info.get('label', svc)
    total = info.get('totalLines', 0)
    ec = info.get('errorCount', 0)
    wc = info.get('warningCount', 0)
    status = '\033[0;32mhealthy\033[0m'
    if ec > 0: status = f'\033[0;31m{ec} errors\033[0m'
    elif wc > 0: status = f'\033[0;33m{wc} warnings\033[0m'
    print(f'  {label}: {status} ({total} lines)')
    for e in errors[-5:]:
        print(f'    \033[0;31mERR\033[0m {e.get(\"timestamp\",\"\")} {e.get(\"message\",\"\")[:100]}')
    for w in warnings[-5:]:
        print(f'    \033[0;33mWRN\033[0m {w.get(\"timestamp\",\"\")} {w.get(\"message\",\"\")[:100]}')
"
      else
        warn "API unavailable, trying SSH..."
        require_ssh
        ec2 "docker logs mmga-expense-app-1 --tail ${lines} 2>&1 | grep -v '302 Found' | grep -v 'GET / HTTP'"
      fi
      ;;

    agent)
      local claim_id="${1:-}"
      if [ -z "$claim_id" ]; then
        err "Usage: mmga logs agent <claim-id-prefix>"
        err "Example: mmga logs agent 6bc295fd"
        return 1
      fi
      header "Agent Trace: ${claim_id}"
      if has_ssh; then
        ec2 "docker logs mmga-expense-app-1 2>&1 | grep '${claim_id}'" | python3 -c "
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line.startswith('{'):
        continue
    try:
        obj = json.loads(line)
        ts = obj.get('asctime', '')[-12:]
        evt = obj.get('event', '')
        msg = obj.get('message', '')
        lvl = obj.get('levelname', 'INFO')
        tool = obj.get('toolName', '')
        model = obj.get('model', '')
        branch = obj.get('branch', '')
        reason = obj.get('reason', '')
        err = obj.get('error', '')[:80] if obj.get('error') else ''

        # Color by level
        if lvl == 'ERROR':   c = '\033[0;31m'
        elif lvl == 'WARNING': c = '\033[0;33m'
        else: c = '\033[0m'

        extra = tool or model or branch or reason or ''
        line_out = f'{c}{ts} [{lvl:7s}] {evt or msg[:60]}'
        if extra: line_out += f' \033[2m{extra}\033[0m'
        if err: line_out += f' \033[0;31merror={err}\033[0m'
        line_out += '\033[0m'
        print(line_out)
    except:
        pass
"
      else
        warn "SSH not available. Agent trace requires SSH access."
        warn "Ask someone with SSH access to run: mmga logs agent ${claim_id}"
        return 1
      fi
      ;;

    download)
      header "Downloading Logs"
      require_ssh
      mkdir -p "$LOGS_DIR"
      local filename="app-$(date +%Y%m%d-%H%M%S).log"
      ec2 "docker logs mmga-expense-app-1 2>&1" > "${LOGS_DIR}/${filename}"
      local lines
      lines=$(wc -l < "${LOGS_DIR}/${filename}")
      ok "Saved ${lines} lines to ${DIM}logs/${filename}${NC}"
      ;;

    clear)
      header "Clearing Logs"
      require_ssh
      for svc in app mcp-rag mcp-db mcp-currency mcp-email qdrant; do
        ec2 "sudo truncate -s 0 \$(sudo docker inspect --format='{{.LogPath}}' mmga-expense-${svc}-1)" && ok "${svc}"
      done
      ;;

    raw)
      local lines="${1:-100}"
      header "Raw App Logs (last ${lines} lines)"
      require_ssh
      ec2 "docker logs mmga-expense-app-1 --tail ${lines} 2>&1 | grep -v '302 Found' | grep -v 'GET / HTTP'"
      ;;

    grep)
      local pattern="${1:-}"
      if [ -z "$pattern" ]; then
        err "Usage: mmga logs grep <pattern>"
        err "Examples:"
        err "  mmga logs grep error"
        err "  mmga logs grep extractReceipt"
        err "  mmga logs grep 'tool.error'"
        return 1
      fi
      header "Logs matching: ${pattern}"
      require_ssh
      ec2 "docker logs mmga-expense-app-1 2>&1 | grep -i '${pattern}'" | python3 -c "
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line.startswith('{'):
        print(line)
        continue
    try:
        obj = json.loads(line)
        ts = obj.get('asctime', '')[-12:]
        lvl = obj.get('levelname', 'INFO')
        evt = obj.get('event', '')
        msg = obj.get('message', '')
        claim = obj.get('claimId', '')[:8] if obj.get('claimId') else ''
        tool = obj.get('toolName', '')
        err_str = obj.get('error', '')[:80] if obj.get('error') else ''
        if lvl == 'ERROR':   c = '\033[0;31m'
        elif lvl == 'WARNING': c = '\033[0;33m'
        else: c = '\033[0m'
        out = f'{c}{ts} [{lvl:7s}] {claim:8s} {evt or msg[:60]}'
        if tool: out += f' \033[2m{tool}\033[0m'
        if err_str: out += f' \033[0;31m{err_str}\033[0m'
        out += '\033[0m'
        print(out)
    except:
        print(line)
" | tail -50
      ;;

    live)
      local lines="${1:-30}"
      header "Live Logs (Ctrl+C to stop)"
      require_ssh
      ssh "$EC2_HOST" "docker logs mmga-expense-app-1 --tail ${lines} -f 2>&1 | grep -v '302 Found' | grep -v 'GET / HTTP'"
      ;;

    sessions)
      header "Recent Sessions"
      require_ssh
      ec2 "docker logs mmga-expense-app-1 2>&1 | grep 'agent.turn_started'" | python3 -c "
import sys, json
from collections import defaultdict
sessions = defaultdict(lambda: {'turns': 0, 'first': '', 'last': '', 'user': '', 'employee': ''})
for line in sys.stdin:
    line = line.strip()
    if not line.startswith('{'): continue
    try:
        obj = json.loads(line)
        cid = obj.get('claimId', '')[:8]
        if not cid: continue
        sessions[cid]['turns'] += 1
        ts = obj.get('asctime', '')[-12:]
        if not sessions[cid]['first']: sessions[cid]['first'] = ts
        sessions[cid]['last'] = ts
        sessions[cid]['user'] = obj.get('username', obj.get('employeeId', ''))
        sessions[cid]['employee'] = obj.get('employeeId', '')
    except: pass

if not sessions:
    print('  No sessions found in current logs.')
else:
    print(f'  {\"CLAIM\":8s}  {\"TURNS\":>5s}  {\"USER\":10s}  {\"FIRST\":>12s}  {\"LAST\":>12s}')
    print(f'  {\"─\"*8}  {\"─\"*5}  {\"─\"*10}  {\"─\"*12}  {\"─\"*12}')
    for cid, s in sorted(sessions.items(), key=lambda x: x[1]['last'], reverse=True):
        print(f'  {cid:8s}  {s[\"turns\"]:5d}  {s[\"user\"]:10s}  {s[\"first\"]:>12s}  {s[\"last\"]:>12s}')
    print()
    print(f'  Trace a session: mmga logs agent <claim-id>')
"
      ;;

    *)
      err "Unknown logs subcommand: ${subcmd}"
      echo
      echo "  Usage: mmga logs <command>"
      echo
      echo "  Commands (no SSH needed):"
      echo "    mmga logs                  Service summary (errors/warnings)"
      echo
      echo "  Commands (SSH required):"
      echo "    mmga logs raw [N]          Last N raw log lines (default 100)"
      echo "    mmga logs grep <pattern>   Search logs for a pattern"
      echo "    mmga logs live [N]         Tail live logs (Ctrl+C to stop)"
      echo "    mmga logs sessions         List recent claim sessions"
      echo "    mmga logs agent <id>       Full agent trace for a claim"
      echo "    mmga logs download         Download full logs to local"
      echo "    mmga logs clear            Truncate all container logs"
      echo
      return 1
      ;;
  esac
}

cmd_models() {
  local subcmd="${1:-show}"
  shift 2>/dev/null || true

  case "$subcmd" in
    show|"")
      header "Current Models"
      local json
      json=$(api_get "/policies/models")
      if [ -n "$json" ] && [ "$json" != "null" ]; then
        echo "$json" | python3 -c "
import sys, json
d = json.load(sys.stdin)
print(f'  \033[1mLLM:\033[0m  {d.get(\"llm\", \"?\")}')
print(f'  \033[1mVLM:\033[0m  {d.get(\"vlm\", \"?\")}')
print()
avail = d.get('available', [])
if avail:
    print('  Available models:')
    for m in avail:
        print(f'    - {m}')
"
      else
        err "Could not fetch models. Are you logged in as a reviewer?"
      fi
      ;;

    set-llm)
      local model="${1:-}"
      if [ -z "$model" ]; then
        err "Usage: mmga models set-llm <model-name>"
        return 1
      fi
      header "Setting LLM: ${model}"
      api_login || return 1
      local resp
      resp=$(curl -s -b "$COOKIE_JAR" -d "llm=${model}&vlm=" -X POST "${APP_URL}/policies/models" 2>/dev/null)
      # Need current VLM to not blank it
      local current_vlm
      current_vlm=$(api_get "/policies/models" | python3 -c "import sys,json; print(json.load(sys.stdin).get('vlm',''))" 2>/dev/null)
      resp=$(curl -s -b "$COOKIE_JAR" -d "llm=${model}&vlm=${current_vlm}" -X POST "${APP_URL}/policies/models" 2>/dev/null)
      ok "LLM set to ${BOLD}${model}${NC}"
      ;;

    set-vlm)
      local model="${1:-}"
      if [ -z "$model" ]; then
        err "Usage: mmga models set-vlm <model-name>"
        return 1
      fi
      header "Setting VLM: ${model}"
      api_login || return 1
      local current_llm
      current_llm=$(api_get "/policies/models" | python3 -c "import sys,json; print(json.load(sys.stdin).get('llm',''))" 2>/dev/null)
      curl -s -b "$COOKIE_JAR" -d "llm=${current_llm}&vlm=${model}" -X POST "${APP_URL}/policies/models" >/dev/null 2>&1
      ok "VLM set to ${BOLD}${model}${NC}"
      ;;

    *)
      err "Unknown models subcommand: ${subcmd}"
      err "Usage: mmga models [show|set-llm <model>|set-vlm <model>]"
      return 1
      ;;
  esac
}

cmd_deploy() {
  require_ssh
  header "Deploying to EC2"

  info "Syncing src/..."
  rsync -avz --exclude '__pycache__' --exclude '.DS_Store' \
    "${LOCAL_ROOT}/src/" "${EC2_HOST}:${EC2_PROJECT}/src/" | tail -3

  info "Syncing templates/..."
  rsync -avz --exclude '__pycache__' --exclude '.DS_Store' \
    "${LOCAL_ROOT}/templates/" "${EC2_HOST}:${EC2_PROJECT}/templates/" | tail -3

  info "Building Docker image..."
  ec2 "cd ${EC2_PROJECT} && docker build -t mmga-app:latest . 2>&1 | tail -3"

  info "Restarting app..."
  ec2 "cd ${EC2_PROJECT} && docker compose -f docker-compose.prod.yml up -d app 2>&1"

  echo
  ok "Deploy complete. Waiting for health check..."
  sleep 8
  cmd_status
}

cmd_restart() {
  require_ssh
  header "Restarting App"
  ec2 "cd ${EC2_PROJECT} && docker compose -f docker-compose.prod.yml restart app 2>&1"
  ok "App restarted."
}

cmd_cleanup() {
  require_ssh
  header "Docker Cleanup"

  info "Before:"
  ec2 "df -h / | awk 'NR==2{print \"  \" \$3\"/\"\$2\" (\" \$5 \")\"}'"

  info "Pruning unused images..."
  ec2 "sudo docker image prune -af 2>&1 | tail -1"

  info "Pruning build cache..."
  ec2 "sudo docker builder prune -af 2>&1 | tail -1"

  info "After:"
  ec2 "df -h / | awk 'NR==2{print \"  \" \$3\"/\"\$2\" (\" \$5 \")\"}'"
}

cmd_ssh() {
  info "Connecting to EC2..."
  ssh -t "$EC2_HOST"
}

cmd_env() {
  require_ssh
  local subcmd="${1:-show}"
  shift 2>/dev/null || true

  case "$subcmd" in
    show|"")
      header "EC2 .env.local"
      ec2 "grep -v '^#' ${EC2_PROJECT}/.env.local | grep -v '^$' | sort" | while read -r line; do
        key="${line%%=*}"
        val="${line#*=}"
        # Redact secrets
        if [[ "$key" =~ (PASSWORD|SECRET|API_KEY) ]]; then
          val="${val:0:4}****"
        fi
        echo -e "  ${BOLD}${key}${NC}=${val}"
      done
      ;;

    set)
      local pair="${1:-}"
      if [ -z "$pair" ] || [[ ! "$pair" =~ = ]]; then
        err "Usage: mmga env set KEY=VALUE"
        return 1
      fi
      local key="${pair%%=*}"
      local value="${pair#*=}"
      header "Setting ${key}"
      ec2 "grep -q '^${key}=' ${EC2_PROJECT}/.env.local && sed -i 's|^${key}=.*|${key}=${value}|' ${EC2_PROJECT}/.env.local || echo '${key}=${value}' >> ${EC2_PROJECT}/.env.local"
      ok "${key}=${value}"
      warn "Restart required: ${DIM}mmga restart${NC}"
      ;;

    *)
      # Treat as a grep filter
      header "EC2 .env.local (filter: ${subcmd})"
      ec2 "grep -i '${subcmd}' ${EC2_PROJECT}/.env.local" | while read -r line; do
        key="${line%%=*}"
        val="${line#*=}"
        if [[ "$key" =~ (PASSWORD|SECRET|API_KEY) ]]; then
          val="${val:0:4}****"
        fi
        echo -e "  ${BOLD}${key}${NC}=${val}"
      done
      ;;
  esac
}

cmd_help() {
  cat <<'HELP'

  mmga — MMGA Expense AI CLI

  ANYONE (API mode — needs reviewer login):
    mmga status                    System health, models, disk
    mmga logs                      Service summary (errors/warnings)
    mmga models                    Show current LLM/VLM models
    mmga models set-llm <model>    Change LLM model at runtime
    mmga models set-vlm <model>    Change VLM model at runtime

  ADMIN (SSH mode — requires EC2 key):
    mmga logs raw [N]              Last N raw log lines (default 100)
    mmga logs grep <pattern>       Search logs (e.g. "error", "tool.error")
    mmga logs live [N]             Tail live logs (Ctrl+C to stop)
    mmga logs sessions             List recent claim sessions
    mmga logs agent <claim-id>     Full agent trace for a claim
    mmga logs download             Download full logs to local
    mmga logs clear                Truncate all container logs
    mmga deploy                    Rsync + rebuild + restart
    mmga restart                   Restart app container
    mmga cleanup                   Prune Docker images + build cache
    mmga ssh                       Drop into EC2 shell
    mmga env                       Show .env.local (secrets redacted)
    mmga env <filter>              Grep .env.local
    mmga env set KEY=VALUE         Update .env.local value

  First run will prompt for login credentials (cached in ~/.mmga_session).

HELP
}

# ── Main ────────────────────────────────────────────────────────────────────
main() {
  local cmd="${1:-help}"
  shift 2>/dev/null || true

  case "$cmd" in
    status)   cmd_status "$@" ;;
    logs)     cmd_logs "$@" ;;
    models)   cmd_models "$@" ;;
    deploy)   cmd_deploy "$@" ;;
    restart)  cmd_restart "$@" ;;
    cleanup)  cmd_cleanup "$@" ;;
    ssh)      cmd_ssh "$@" ;;
    env)      cmd_env "$@" ;;
    help|-h|--help) cmd_help ;;
    *)
      err "Unknown command: ${cmd}"
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
