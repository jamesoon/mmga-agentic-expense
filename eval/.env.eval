# MMGA Evaluation Suite — Environment Variables
# Copy this to .env and fill in your API keys before running eval.

# Required: Judge model (GPT-4o via OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-XXXXX

# Required: Claude subagent for browser capture
ANTHROPIC_API_KEY=sk-ant-XXXXX

# Target app (default: AWS deployment)
EVAL_APP_URL=https://mmga.mdaie-sutd.fit

# Login credentials (reviewer role)
EVAL_USERNAME=james
EVAL_PASSWORD=james123

# Database (for enrichment step — RDS endpoint)
DATABASE_URL=postgresql://agentic:agentic_password@mmga-expense-postgres.cfg6qy4oqaqg.ap-southeast-1.rds.amazonaws.com:5432/agentic_claims

# Qdrant (for retrieval metrics — not directly accessible from outside EC2)
# QDRANT_URL=http://localhost:6333

# To run against local Docker instead of AWS:
# EVAL_APP_URL=http://localhost:8000
# DATABASE_URL=postgresql://agentic:agentic_password@localhost:5432/agentic_claims
