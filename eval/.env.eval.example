# MMGA Evaluation Suite — Environment Variables (template)
# Copy to `.env.eval` and fill in real values before running eval.
# The real .env.eval file is gitignored.

# Required: Judge model (OpenRouter)
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME

# Required: Anthropic key for Claude subagent browser capture
ANTHROPIC_API_KEY=sk-ant-api-REPLACE_ME

# Target app URL (prod default)
EVAL_APP_URL=https://mmga.mdaie-sutd.fit

# Reviewer login for browser capture
EVAL_USERNAME=REPLACE_ME
EVAL_PASSWORD=REPLACE_ME

# Database (for enrichment — RDS endpoint or local)
DATABASE_URL=postgresql://REPLACE_ME:REPLACE_ME@REPLACE_ME:5432/REPLACE_ME

# To run against local Docker instead of AWS:
# EVAL_APP_URL=http://localhost:8000
# DATABASE_URL=postgresql://agentic:agentic_password@localhost:5432/agentic_claims
