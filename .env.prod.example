# Production environment — deployed to AWS EC2 + RDS + Lambda.
# Copy to .env.prod and fill in values. The deploy scripts inject
# RDS_ENDPOINT, DB_MCP_URL, CURRENCY_MCP_URL, EMAIL_MCP_URL automatically.

# ─── PostgreSQL (RDS) ──────────────────────────────────────────────
POSTGRES_HOST=INJECTED_BY_DEPLOY_SCRIPT
POSTGRES_PORT=5432
POSTGRES_DB=agentic_claims
POSTGRES_USER=agentic
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ─── RDS endpoint (set by deploy script) ───────────────────────────
RDS_ENDPOINT=INJECTED_BY_DEPLOY_SCRIPT

# ─── Application ───────────────────────────────────────────────────
APP_ENV=prod
APP_VERSION=0.9.0
CHAINLIT_HOST=0.0.0.0
CHAINLIT_PORT=8000

# ─── OpenRouter ────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-CHANGE_ME
OPENROUTER_MODEL_LLM=qwen/qwen3-235b-a22b-2507
OPENROUTER_MODEL_VLM=google/gemini-2.0-flash-001
OPENROUTER_FALLBACK_MODEL_LLM=google/gemini-2.0-flash-lite-001
OPENROUTER_FALLBACK_MODEL_VLM=google/gemini-2.0-flash-lite-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_DELAY=2.0
OPENROUTER_VLM_MAX_TOKENS=4096
OPENROUTER_LLM_MAX_TOKENS=8192
OPENROUTER_LLM_TEMPERATURE=0.3
OPENROUTER_TIMEOUT=120

# ─── Qdrant (local on EC2, accessed via Docker network) ───────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ─── MCP Server URLs ──────────────────────────────────────────────
# RAG runs on EC2 alongside app
RAG_MCP_URL=http://mcp-rag:8000/mcp/
# These are Lambda Function URLs — injected by deploy script
DB_MCP_URL=INJECTED_BY_DEPLOY_SCRIPT
CURRENCY_MCP_URL=INJECTED_BY_DEPLOY_SCRIPT
EMAIL_MCP_URL=INJECTED_BY_DEPLOY_SCRIPT

# ─── SMTP (production) ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=

# ─── Image Quality ─────────────────────────────────────────────────
IMAGE_QUALITY_THRESHOLD=150.0
IMAGE_MIN_WIDTH=400
IMAGE_MIN_HEIGHT=600
VLM_CONFIDENCE_THRESHOLD=0.7

# ─── Session ───────────────────────────────────────────────────────
SESSION_SECRET_KEY=CHANGE_ME_RANDOM_SECRET

# ─── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=INFO
ENABLE_RESPONSE_STREAMING=false
