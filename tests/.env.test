# Test PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentic_claims_test
POSTGRES_USER=test_user
POSTGRES_PASSWORD=test_password

# Test Chainlit Configuration
CHAINLIT_HOST=127.0.0.1
CHAINLIT_PORT=8001

# Test Application Environment
APP_ENV=test

# Test OpenRouter Configuration (use test-safe values)
OPENROUTER_API_KEY=test-key-not-real
OPENROUTER_MODEL_LLM=test-llm-model
OPENROUTER_MODEL_VLM=test-vlm-model
OPENROUTER_FALLBACK_MODEL_LLM=test-fallback-llm-model
OPENROUTER_FALLBACK_MODEL_VLM=test-fallback-vlm-model
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MAX_RETRIES=3
OPENROUTER_RETRY_DELAY=0.1
OPENROUTER_VLM_MAX_TOKENS=4096
OPENROUTER_LLM_MAX_TOKENS=8192
OPENROUTER_LLM_TEMPERATURE=0.3
OPENROUTER_TIMEOUT=30
ENABLE_RESPONSE_STREAMING=false

# Test Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Test MCP Server URLs (localhost for tests)
RAG_MCP_URL=http://localhost:8001/mcp/
DB_MCP_URL=http://localhost:8002/mcp/
CURRENCY_MCP_URL=http://localhost:8003/mcp/
EMAIL_MCP_URL=http://localhost:8004/mcp/

# Test Image Quality Settings
IMAGE_QUALITY_THRESHOLD=150.0
IMAGE_MIN_WIDTH=800
IMAGE_MIN_HEIGHT=600

# Test VLM Confidence Threshold
VLM_CONFIDENCE_THRESHOLD=0.7

# Test Session Configuration
SESSION_SECRET_KEY=test-secret-key

# Test Logging Configuration
LOG_LEVEL=DEBUG
LOG_FILE_PATH=
SEQ_URL=http://localhost:5341
SEQ_PASSWORD=test
SEQ_INGESTION_URL=

# Spec A — compliance hardening
HARD_CAP_PER_RECEIPT_SGD=5000.0
HARD_CAP_PER_CLAIM_SGD=10000.0
HARD_CAP_PER_EMPLOYEE_PER_MONTH_SGD=20000.0
SOFT_CAP_MULTIPLIER=1.5
COMPLIANCE_CRITIQUE_ENABLED=true
COMPLIANCE_CRITIQUE_TEMPERATURE=0.0
# Optional: pin a specific critique model; if unset the system falls back to OPENROUTER_FALLBACK_MODEL_LLM
COMPLIANCE_CRITIQUE_MODEL=

# Spec A — abuse boundaries
MAX_JUSTIFICATION_CHARS=500
MAX_MESSAGE_CHARS=2000
RATE_LIMIT_MESSAGES_PER_MIN=20
QUOTA_SUBMISSIONS_PER_DAY=20
QUOTA_RETRIES_PER_HOUR=5

# Spec B — evaluation harness
EVAL_VERIFIER_MODEL=anthropic/claude-haiku-4-5
EVAL_SELF_CONSISTENCY_RUNS=3
EVAL_DISAGREEMENT_THRESHOLD=0.25
EVAL_MAX_PLAYGROUND_CALLS_PER_MIN=5
EVAL_MAX_RUNS_PER_HOUR=1
EVAL_MAX_RESULT_JSON_MB=10
EVAL_MAX_COST_USD_PER_RUN=10.0
# EVAL_JUDGE_MODEL=   # Optional; defaults to OPENROUTER_MODEL_LLM
